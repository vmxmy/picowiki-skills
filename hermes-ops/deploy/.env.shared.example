# ═════════════════════════════════════════════════════════════════════════════
# Hermes Agent — Shared Infrastructure Configuration
#
# Applied to ALL tenants. Tenant-specific .env files override these values.
# Put keys here that are truly shared (same LLM account, same tool APIs).
# Move any key to tenants/<name>/.env to make it tenant-specific.
# ═════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (pick one or more) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# GOOGLE_API_KEY=...

# ── Terminal execution backend ────────────────────────────────────────────────
# "local" runs commands inside the container itself (safe — already isolated).
# Use "docker" or "modal" if you need a nested sandbox inside the container.
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# ── Gateway-wide defaults ─────────────────────────────────────────────────────
# Keep false — use TELEGRAM_ALLOWED_USERS / DISCORD_ALLOWED_USERS per tenant.
GATEWAY_ALLOW_ALL_USERS=false

# ── Optional shared tool API keys ────────────────────────────────────────────
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# FAL_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

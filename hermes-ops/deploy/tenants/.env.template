# ═════════════════════════════════════════════════════════════════════════════
# Hermes Agent — Tenant Configuration Template
#
# Copy to tenants/<name>/.env and fill in the platforms this tenant uses.
# Uncomment only the platforms you need — unused platforms stay disabled.
#
# Env var loading order: .env.shared → this file (this file wins on conflict).
# ═════════════════════════════════════════════════════════════════════════════

# ── Override shared LLM key (leave commented to use shared key) ───────────────
# ANTHROPIC_API_KEY=sk-ant-tenant-specific...
# OPENROUTER_API_KEY=sk-or-tenant-specific...

# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM
# Get token from @BotFather: https://t.me/BotFather
# Get user IDs from @userinfobot
# ─────────────────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=1234567890:AAF_your_bot_token_here
# TELEGRAM_ALLOWED_USERS=123456789,987654321   # Comma-separated Telegram user IDs
# TELEGRAM_HOME_CHANNEL=123456789              # Default chat for cron job delivery
# TELEGRAM_REQUIRE_MENTION=false               # Require @BotName mention in groups
# TELEGRAM_REPLY_TO_MODE=first                 # "off" | "first" | "all"

# Webhook mode (leave unset for long-polling — simpler, no public URL needed)
# TELEGRAM_WEBHOOK_URL=https://my-server.example.com/telegram
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=random_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# DISCORD
# Create bot at: https://discord.com/developers/applications
# Required intents: Message Content, Server Members
# ─────────────────────────────────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=MTIz_your_discord_bot_token_here
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432
# DISCORD_HOME_CHANNEL=123456789012345678      # Channel ID for cron delivery
# DISCORD_REQUIRE_MENTION=true                 # Require @BotName mention
# DISCORD_AUTO_THREAD=false                    # Auto-create threads for responses
# DISCORD_REPLY_TO_MODE=first                  # "off" | "first" | "all"

# ─────────────────────────────────────────────────────────────────────────────
# SLACK
# Create app at: https://api.slack.com/apps
# Scopes needed: app_mentions:read, channels:history, chat:write, im:history
# Enable Socket Mode for SLACK_APP_TOKEN
# ─────────────────────────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token    # Required for Socket Mode
# SLACK_ALLOWED_USERS=U01234567,U09876543      # Comma-separated Slack user IDs
# SLACK_HOME_CHANNEL=C01234567                 # Channel ID for cron delivery
# SLACK_REQUIRE_MENTION=false

# ─────────────────────────────────────────────────────────────────────────────
# SIGNAL (via signal-cli HTTP)
# Run signal-cli: https://github.com/AsamK/signal-cli
# ─────────────────────────────────────────────────────────────────────────────
# SIGNAL_HTTP_URL=http://localhost:8080        # signal-cli REST API endpoint
# SIGNAL_ACCOUNT=+15551234567                 # Registered Signal phone number
# SIGNAL_HOME_CHANNEL=+15559876543            # Default delivery number

# ─────────────────────────────────────────────────────────────────────────────
# MATRIX
# ─────────────────────────────────────────────────────────────────────────────
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=syt_your_access_token
# MATRIX_USER_ID=@yourbot:matrix.org
# MATRIX_HOME_ROOM=!roomid:matrix.org

# ─────────────────────────────────────────────────────────────────────────────
# API SERVER (REST endpoint — each tenant needs a unique port)
# ─────────────────────────────────────────────────────────────────────────────
# API_SERVER_ENABLED=false
# API_SERVER_PORT=8000          # MUST be unique per tenant; expose in compose
# API_SERVER_KEY=your-bearer-token-for-auth
# API_SERVER_CORS_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP (built-in Baileys bridge — pair via `docker exec -it hermes-<name> hermes whatsapp`)
# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP_ENABLED=false
# WHATSAPP_ALLOWED_USERS=15551234567          # Phone number without +

# Runtime data for each tenant — keep the data/ directory but ignore its contents.
# Sessions, memories, logs, and config are written here by the running container.
tenants/*/data/*
!tenants/*/data/.gitkeep

# Archived tenants (created by remove-tenant.sh default mode)
tenants/.archive/

# Secrets — copy from examples and fill in locally, never commit
.env.shared
tenants/*/.env

# OMC tool state
.omc/
